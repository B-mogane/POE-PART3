<Window x:Class="Bot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Cybersecurity Awareness Bot" Height="600" Width="900"
        Background="#1a1a2e">

    <Window.Resources>
       
        <Style TargetType="TabItem">
            <Setter Property="Background"   Value="#252545"/>
            <Setter Property="Foreground"   Value="#aaaacc"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="14,6"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0d0d1f"/>
                    <Setter Property="Foreground" Value="#4c8cff"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style TargetType="ListBox">
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

       
        <Border Background="#0a0f1a" Padding="8">
            <StackPanel>
                <TextBlock FontFamily="Consolas"
                           FontSize="8.5"
                           Foreground="#4c8cff"
                           TextAlignment="Center"
                           xml:space="preserve">
     ▄████████  ▄█   ▄█          ▄████████    ▄████████ 
    ███    ███ ███  ███         ███    ███   ███    ███ 
    ███    █▀  ███▌ ███         ███    █▀    ███    █▀  
    ███        ███▌ ███        ▄███▄▄▄       ███        
  ▀███████████ ███▌ ███       ▀▀███▀▀▀     ▀███████████ 
           ███ ███  ███         ███    █▄           ███ 
     ▄█    ███ ███  ███▌    ▄   ███    ███    ▄█    ███ 
   ▄████████▀  █▀   █████▄▄██   ██████████  ▄████████▀  
                    ▀           CYBERSECURITY AWARENESS BOT</TextBlock>

                <Border Background="#2a2a4a" CornerRadius="4" Margin="4,4,4,0" Padding="8,4">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text=" Name: "  Foreground="#aaa"/>
                        <TextBlock x:Name="TxtName"     Text="?"  Foreground="#4caf50" Margin="0,0,20,0"/>
                        <TextBlock Text="⭐ Interest: " Foreground="#aaa"/>
                        <TextBlock x:Name="TxtInterest" Text="?"  Foreground="#ffa726"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

       
        <TabControl Grid.Row="1" Background="#0d0d1f" BorderBrush="#333">

           
            <TabItem Header="Chat">
                <Grid Background="#0d0d1f" Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="ChatList"
                             Background="#181830"
                             BorderBrush="#333"
                             Foreground="#e0e0ff"
                             FontSize="13"
                             FontFamily="Consolas"
                             Margin="0,0,0,6"
                             Padding="4">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="4,3"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#1a1a3a"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <Border Grid.Row="1" Background="#1e1e3e" CornerRadius="6" Padding="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="InputBox"
                                     Background="#2a2a4a"
                                     Foreground="White"
                                     CaretBrush="White"
                                     BorderBrush="#4c8cff"
                                     KeyDown="InputBox_KeyDown"
                                     FontSize="14"
                                     Padding="8,6"/>
                            <Button Grid.Column="1"
                                    Content="Send "
                                    Click="Send_Click"
                                    Background="#2E7D32"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    BorderThickness="0"
                                    Margin="6,0,0,0"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header=" Tasks">
                <Grid Background="#0d0d1f" Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Foreground="#aaaacc" FontSize="12" Margin="0,0,0,8"
                               TextWrapping="Wrap">
                        Tip: You can manage tasks from the Chat tab too — just say
                        'add task', 'view tasks', 'complete task 2', or 'delete task 3'.
                    </TextBlock>

                    <ListBox x:Name="TaskList"
                             Grid.Row="1"
                             Background="#181830"
                             BorderBrush="#333"
                             Foreground="#e0e0ff"
                             FontSize="13"
                             Padding="4"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content=" Refresh Tasks"
                                Click="RefreshTasks_Click"
                                Background="#1565C0" Foreground="White"
                                FontWeight="Bold" BorderThickness="0"
                                Padding="12,6" Margin="0,0,8,0"/>
                        <Button Content=" Complete Selected"
                                Click="CompleteSelected_Click"
                                Background="#2E7D32" Foreground="White"
                                FontWeight="Bold" BorderThickness="0"
                                Padding="12,6" Margin="0,0,8,0"/>
                        <Button Content=" Delete Selected"
                                Click="DeleteSelected_Click"
                                Background="#c62828" Foreground="White"
                                FontWeight="Bold" BorderThickness="0"
                                Padding="12,6"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            
            <TabItem Header=" Activity Log">
                <Grid Background="#0d0d1f" Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="LogList"
                             Background="#181830"
                             BorderBrush="#333"
                             Foreground="#b0ffc0"
                             FontSize="12"
                             FontFamily="Consolas"
                             Padding="4"/>

                    <Button Grid.Row="1"
                            Content=" Refresh Log"
                            Click="RefreshLog_Click"
                            Background="#1565C0" Foreground="White"
                            FontWeight="Bold" BorderThickness="0"
                            Padding="12,6" Margin="0,8,0,0"
                            HorizontalAlignment="Left"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
